OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
NEW_PER_DAY=10

# Host port to publish the app on. Default 8080. Change if another service
# (e.g. a work app) is already on 8080.
HTTP_PORT=8080

# When true, also create English→Swedish flashcards for word/phrase/verb
# entries (doubles vocabulary card count). Default false.
REVERSE_CARDS=false
